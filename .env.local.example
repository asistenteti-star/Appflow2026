# ==============================================================
#  Alzak Flow — Variables de entorno del Frontend
#  En Vercel: Settings → Environment Variables → pega cada clave
#  En local:  copia este archivo como .env.local y ajusta valores
# ==============================================================

# URL completa del backend Express + Socket.io
# Tunnel activo (Cloudflare): https://autos-coding-documents-blank.trycloudflare.com
# Local (desarrollo):         http://localhost:3005
NEXT_PUBLIC_API_URL=https://autos-coding-documents-blank.trycloudflare.com

# URL del servidor Socket.io — misma que la API (Socket.io corre en el mismo proceso)
NEXT_PUBLIC_SOCKET_URL=https://autos-coding-documents-blank.trycloudflare.com
