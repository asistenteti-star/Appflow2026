# ==============================================================
#  Alzak Flow — Variables de entorno del Frontend
#  Copia este archivo como .env.local para desarrollo local,
#  o carga estas variables en Vercel → Settings → Environment Variables
# ==============================================================

# URL completa del backend (Express + Socket.io)
# Ejemplos:
#   Local:      http://localhost:3005
#   Producción: https://api.alzakfoundation.org
NEXT_PUBLIC_API_URL=http://localhost:3005

# URL del servidor Socket.io (normalmente la misma que la API)
# Socket.io corre en el mismo puerto que Express
NEXT_PUBLIC_SOCKET_URL=http://localhost:3005
